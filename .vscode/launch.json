{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "RigBridge API Server",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_api.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [],
      "env": {
        "PYTHONUNBUFFERED": "1"
      },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "RigBridge API Server (cProfile)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_api.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "--profile",
        "--profile-output",
        "profile_debug.out"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1"
      },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "RigBridge Integration Test",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/test_integration.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Python: Debug Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/",
        "-v",
        "--tb=short"
      ],
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}"
    }
  ]
}

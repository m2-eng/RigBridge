# ──────────────────────────────────────────────────────────────────────────────
# .env.example – RigBridge Umgebungsvariablen (Vorlage)
# Diese Datei wird versioniert. Die echte .env-Datei liegt in .gitignore!
# Kopieren: cp .env.example .env  und dann die Werte anpassen.
# ──────────────────────────────────────────────────────────────────────────────

# ── API-Server ────────────────────────────────────────────────────────────────
API_PORT=8080
API_HOST=0.0.0.0

# ── USB / Serial ─────────────────────────────────────────────────────────────# Linux (Produktion / Docker):  /dev/ttyUSB0  oder  /dev/ttyACM0
# Windows (Entwicklung nativ):  COM3          oder  COM4USB_PORT=/dev/ttyUSB0
USB_BAUD_RATE=19200

# ── CAT-Schnittstelle (Wavelog) ───────────────────────────────────────────────
CAT_PORT=4532
WAVELOG_API_KEY=change_me
WAVELOG_API_URL=https://your-wavelog-instance.example.com/api

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

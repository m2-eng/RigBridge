# ──────────────────────────────────────────────────────────────────────────────
# .env.example – RigBridge Umgebungsvariablen (Vorlage)
# Diese Datei wird versioniert. Die echte .env-Datei liegt in .gitignore!
# Kopieren: cp .env.example .env  und dann die Werte anpassen.
# ──────────────────────────────────────────────────────────────────────────────

# ============================================================================
# USB / Serial-Konfiguration
# ============================================================================
# Linux (Produktion / Docker):  /dev/ttyUSB0  oder  /dev/ttyACM0
# Windows (Entwicklung nativ):  COM3          oder  COM4
RIGBRIDGE_USB_PORT=/dev/ttyUSB0
RIGBRIDGE_USB_BAUD=19200

# ============================================================================
# API-Server
# ============================================================================
RIGBRIDGE_API_HOST=127.0.0.1                 # 127.0.0.1 = nur lokal (sicher)
RIGBRIDGE_API_PORT=8080
RIGBRIDGE_LOG_LEVEL=INFO                     # DEBUG, INFO, WARNING, ERROR

# ============================================================================
# Wavelog CAT-Integration (optional)
# ============================================================================
RIGBRIDGE_WAVELOG_ENABLED=false
RIGBRIDGE_WAVELOG_URL=https://api.wavelog.local
RIGBRIDGE_WAVELOG_KEY=your-api-key-here      # Wird verschlüsselt gespeichert!

# ============================================================================
# Funkgerät
# ============================================================================
RIGBRIDGE_DEVICE_NAME=Icom IC-905
